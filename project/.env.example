# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=recommendation_system
MONGO_COLLECTION_USERS=users
MONGO_COLLECTION_RATINGS=ratings
MONGO_COLLECTION_RECOMMENDATIONS=recommendations

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Movie Recommendation System API
API_VERSION=1.0.0

# Model Configuration
MODEL_TYPE=svd  # Options: svd, content_based, hybrid
N_FACTORS=50
LEARNING_RATE=0.005
N_EPOCHS=100
MIN_RATING=1
MAX_RATING=5

# Recommendation Configuration
TOP_N_RECOMMENDATIONS=5
COLD_START_STRATEGY=popular  # Options: popular, random

# Application Configuration
DEBUG=True
LOG_LEVEL=INFO
RANDOM_SEED=42

# Jupyter/Streamlit Configuration
STREAMLIT_PORT=8501
STREAMLIT_HOST=localhost
